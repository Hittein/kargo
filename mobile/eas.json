{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kargo-api.onrender.com/api/v1"
      },
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kargo-api.onrender.com/api/v1"
      },
      "android": { "buildType": "apk" },
      "ios": { "simulator": false }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kargo-api.onrender.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "bundleIdentifier": "com.kargo.client"
      }
    }
  }
}
